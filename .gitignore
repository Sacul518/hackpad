# KiCad backups & autosaves
*-backups/
*.bak
*.kicad_pcb-bak
*.kicad_sch-bak
_autosave-*
fp-info-cache

# KiCad lock files
~*.lck

# KiCad local project settings (per-machine GUI state)
*.kicad_prl

# macOS
.DS_Store

# VS Code "Local History" extension
.history/

# Python caches
__pycache__/
*.pyc

# CircuitPython library bundle (copied onto the device, not versioned)
firmware/lib/*
!firmware/lib/README.md

# App: virtualenv + local working copy
app/.venv/
app/last_config.json

# App: PyInstaller build output
app/build/
app/dist/
app/*.spec
Pictures/
Ship/
submission/
